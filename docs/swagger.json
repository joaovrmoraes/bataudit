    "definitions": {
        "audit.Audit": {
            "type": "object"
        },
        "audit.AuditStats": {
            "type": "object",
            "properties": {
                "active_services": {
                    "type": "integer"
                },
                "avg_response_time": {
                    "type": "number"
                },
                "by_method": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "integer"
                    }
                },
                "by_service": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/audit.ServiceBreakdown"
                    }
                },
                "by_status_class": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "integer"
                    }
                },
                "errors_4xx": {
                    "type": "integer"
                },
                "errors_5xx": {
                    "type": "integer"
                },
                "last_event_at": {
                    "type": "string"
                },
                "p95_response_time": {
                    "type": "number"
                },
                "timeline": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/audit.TimelinePoint"
                    }
                },
                "total": {
                    "type": "integer"
                }
            }
        },
        "audit.HTTPMethod": {
            "type": "string",
            "enum": [
                "GET",
                "POST",
                "PUT",
                "DELETE"
            ],
            "x-enum-varnames": [
                "GET",
                "POST",
                "PUT",
                "DELETE"
            ]
        },
        "audit.ServiceBreakdown": {
            "type": "object",
            "properties": {
                "avg_response_time": {
                    "type": "number"
                },
                "errors": {
                    "type": "integer"
                },
                "last_event": {
                    "type": "string"
                },
                "requests": {
                    "type": "integer"
                },
                "service_name": {
                    "type": "string"
                }
            }
        },
        "audit.TimelinePoint": {
            "type": "object",
            "properties": {
                "count": {
                    "type": "integer"
                },
                "hour": {
                    "type": "string"
                }
            }
        },
        "auth.Project": {
            "type": "object",
            "properties": {
                "created_at": {
                    "type": "string"
                },
                "created_by": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                },
                "slug": {
                    "type": "string"
                }
            }
        },
        "auth.UserRole": {
            "type": "string",
            "enum": [
                "owner",
                "admin",
                "viewer"
            ],
            "x-enum-varnames": [
                "RoleOwner",
                "RoleAdmin",
                "RoleViewer"
            ]
        },
        "auth.addMemberRequest": {
            "type": "object",
            "required": [
                "email",
                "role"
            ],
            "properties": {
                "email": {
                    "type": "string"
                },
                "role": {
                    "$ref": "#/definitions/auth.UserRole"
                }
            }
        },
        "auth.createAPIKeyRequest": {
            "type": "object",
            "required": [
                "name",
                "project_id"
            ],
            "properties": {
                "name": {
                    "type": "string",
                    "maxLength": 128,
                    "minLength": 1
                },
                "project_id": {
                    "type": "string"
                }
            }
        },
        "auth.createProjectRequest": {
            "type": "object",
            "required": [
                "name",
                "slug"
            ],
            "properties": {
                "name": {
                    "type": "string",
                    "maxLength": 128,
                    "minLength": 1
                },
                "slug": {
                    "type": "string",
